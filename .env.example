# =============================================================================
# .env.example — DealSim environment variable reference
#
# Copy this file to .env and fill in the values before deploying.
#   cp .env.example .env
#
# The .env file is listed in .gitignore and must never be committed.
# All variables listed here are read by docker-compose.yml via env_file.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime environment
# "production" enables production logging, stricter error handling.
# "development" enables auto-reload and verbose output.
# -----------------------------------------------------------------------------
DEALSIM_ENV=production

# -----------------------------------------------------------------------------
# Server binding
# HOST should stay 0.0.0.0 inside Docker (nginx handles external access).
# PORT is the internal uvicorn port; nginx proxies to it.
# -----------------------------------------------------------------------------
DEALSIM_HOST=0.0.0.0
DEALSIM_PORT=8000

# -----------------------------------------------------------------------------
# Workers
# Production: 2 workers (matches 0.5 CPU limit — 1 per allocated core).
# Development override.yml sets this to 1 automatically.
# Rule of thumb: (2 * CPU_cores) + 1, capped at available CPU budget.
# -----------------------------------------------------------------------------
DEALSIM_WORKERS=2

# -----------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed origins for browser requests.
# Must include the exact scheme and domain of your frontend.
# Example: https://dealsim.app,https://www.dealsim.app
# -----------------------------------------------------------------------------
DEALSIM_CORS_ORIGINS=https://yourdomain.com

# -----------------------------------------------------------------------------
# Admin API key
# Used to authenticate requests to /admin/* endpoints.
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
# IMPORTANT: Generate a secure key before deploying!
# Run: openssl rand -hex 32
# Then paste the output here. NEVER use the placeholder value.
DEALSIM_ADMIN_KEY=GENERATE_WITH_openssl_rand_-hex_32

# -----------------------------------------------------------------------------
# Session limits
# MAX_SESSIONS: maximum number of concurrent in-memory sessions.
# SESSION_TTL_HOURS: idle sessions are expired after this many hours.
# -----------------------------------------------------------------------------
DEALSIM_MAX_SESSIONS=1000
DEALSIM_SESSION_TTL_HOURS=1

# -----------------------------------------------------------------------------
# Data directory
# Where the app writes JSONL files (events, feedback, submissions).
# Must match the volume mount target in docker-compose.yml.
# Do not change unless you also update the compose volume mapping.
# -----------------------------------------------------------------------------
DEALSIM_DATA_DIR=/app/data

# -----------------------------------------------------------------------------
# Domain (used by scripts/deploy.sh and nginx config templating)
# Set to the public-facing domain name, without scheme or trailing slash.
# Example: dealsim.app
# -----------------------------------------------------------------------------
DEALSIM_DOMAIN=yourdomain.com

# -----------------------------------------------------------------------------
# Let's Encrypt contact email
# Certbot sends expiry notices to this address.
# -----------------------------------------------------------------------------
DEALSIM_EMAIL=admin@yourdomain.com

# -----------------------------------------------------------------------------
# Backup configuration (used by scripts/backup.sh)
# BACKUP_DIR: local directory where compressed backup archives are stored.
# BACKUP_RETAIN_DAYS: number of daily archives to keep before rotation.
# -----------------------------------------------------------------------------
BACKUP_DIR=/opt/backups/dealsim
BACKUP_RETAIN_DAYS=7

# -----------------------------------------------------------------------------
# Optional: Telegram alerts (used by scripts/backup.sh)
# Leave empty to disable alert notifications.
# TELEGRAM_BOT_TOKEN: token from BotFather
# TELEGRAM_CHAT_ID: your personal or group chat ID
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# LLM-Powered Negotiation Engine (optional — falls back to rule-based if disabled or API key missing)
# Set DEALSIM_USE_LLM=true and supply LLM_API_KEY to activate.
# The app calls the LLM provider directly — no extra container required.
# Supports any OpenAI-compatible API (DeepSeek, OpenAI, etc.).
# LLM_API_KEY: your DeepSeek or OpenAI-compatible API key
# LLM_BASE_URL: provider base URL (default: DeepSeek)
# LLM_MODEL: model identifier to request
# LLM_TEMPERATURE: sampling temperature (0.0–1.0; default 0.7)
# LLM_MAX_TOKENS: maximum tokens per response (default 300)
# LLM_TIMEOUT: HTTP request timeout in seconds (default 30)
# -----------------------------------------------------------------------------
DEALSIM_USE_LLM=false
LLM_API_KEY=your-deepseek-or-openai-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=300
LLM_TIMEOUT=30

# -----------------------------------------------------------------------------
# MiroFish Multi-Agent Engine (optional — falls back to rule-based if unreachable)
# MiroFish runs as a separate Docker container. When MIROFISH_BASE_URL is set
# and the container is reachable, the engine factory auto-selects it as the
# primary negotiation engine with fallback to LLM → rule-based.
# To run MiroFish: docker run -p 5001:5001 mirofish/mirofish:latest
# -----------------------------------------------------------------------------
MIROFISH_BASE_URL=
MIROFISH_TIMEOUT=30.0
MIROFISH_RETRY_ATTEMPTS=3
MIROFISH_RETRY_BACKOFF=1.5
